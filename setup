#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# ai-coding-setup installer
# Installs AI coding agent commands/skills for Claude Code, Gemini CLI,
# and Codex CLI from this repo into user-level directories.
# ---------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

MD_MARKER="<!-- source: ai-coding-setup -->"
TOML_MARKER="# source: ai-coding-setup"

# ---- helpers --------------------------------------------------------------

print_success() { echo -e "${GREEN}[OK]${NC} $1"; }
print_error()   { echo -e "${RED}[ERROR]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }
print_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }

prompt_yes_no() {
    local prompt="$1"
    local default="${2:-y}"
    local yn
    if [[ "$default" == "y" ]]; then
        read -rp "$(echo -e "${BOLD}${prompt}${NC} [Y/n]: ")" yn
        yn="${yn:-y}"
    else
        read -rp "$(echo -e "${BOLD}${prompt}${NC} [y/N]: ")" yn
        yn="${yn:-n}"
    fi
    [[ "$yn" =~ ^[Yy]$ ]]
}

# Extract description from a Claude .md command file.
# Returns the first non-blank, non-heading line.
get_md_description() {
    local file="$1"
    local desc
    desc=$(grep -m 1 -v -E '^\s*$|^\s*#|^---' "$file" | head -1)
    echo "${desc:-No description available}"
}

# Extract description from a Gemini .toml command file.
# Parses the description = "..." field.
get_toml_description() {
    local file="$1"
    local desc
    desc=$(grep -m 1 '^description' "$file" | sed 's/^description[[:space:]]*=[[:space:]]*"\(.*\)"/\1/')
    echo "${desc:-No description available}"
}

# Extract description from a Codex SKILL.md file.
# Parses the description: field from YAML front matter.
get_skill_description() {
    local file="$1"
    local desc
    desc=$(grep -m 1 '^description:' "$file" | sed 's/^description:[[:space:]]*"\{0,1\}\(.*[^"]\)"\{0,1\}$/\1/')
    echo "${desc:-No description available}"
}

has_md_marker() {
    grep -qF "$MD_MARKER" "$1" 2>/dev/null
}

has_toml_marker() {
    grep -qF "$TOML_MARKER" "$1" 2>/dev/null
}

# ---- prerequisite checks --------------------------------------------------

# Must be run from repo root
if [[ ! -d ".claude/commands" ]] && [[ ! -d ".gemini/commands" ]] && [[ ! -d ".codex/skills" ]]; then
    print_error "No command directories found (.claude/commands, .gemini/commands, .codex/skills)."
    print_error "Please run this script from the ai-coding-setup repository root."
    exit 1
fi

# GitHub CLI required
if ! command -v gh &>/dev/null; then
    print_error "GitHub CLI (gh) is not installed."
    echo ""
    echo "  Install it from: https://cli.github.com/"
    echo "  Or via Homebrew:  brew install gh"
    echo ""
    exit 1
fi

# ---- detect installed tools -----------------------------------------------

detected_tools=()

if [[ -d "$HOME/.claude" ]]; then
    detected_tools+=("claude")
fi

if command -v gemini &>/dev/null || [[ -d "$HOME/.gemini" ]]; then
    detected_tools+=("gemini")
fi

if command -v codex &>/dev/null || [[ -d "$HOME/.codex" ]]; then
    detected_tools+=("codex")
fi

if [[ ${#detected_tools[@]} -eq 0 ]]; then
    print_error "No supported AI coding tools detected."
    echo ""
    echo "  Install at least one of:"
    echo "  - Claude Code:  https://docs.anthropic.com/en/docs/claude-code"
    echo "  - Gemini CLI:   https://github.com/google-gemini/gemini-cli"
    echo "  - Codex CLI:    https://github.com/openai/codex"
    echo ""
    exit 1
fi

# ---- tool selection --------------------------------------------------------

echo ""
print_info "Detected AI coding tools:"
echo ""

for i in "${!detected_tools[@]}"; do
    tool="${detected_tools[$i]}"
    case "$tool" in
        claude) echo -e "  ${BOLD}$((i + 1)))${NC} Claude Code" ;;
        gemini) echo -e "  ${BOLD}$((i + 1)))${NC} Gemini CLI" ;;
        codex)  echo -e "  ${BOLD}$((i + 1)))${NC} Codex CLI" ;;
    esac
done

echo ""
read -rp "$(echo -e "${BOLD}Which tools to set up? (comma-separated numbers, or 'a' for all):${NC} ")" tool_selection

selected_tools=()
if [[ "$tool_selection" =~ ^[Aa]$ ]]; then
    selected_tools=("${detected_tools[@]}")
else
    IFS=',' read -ra selections <<< "$tool_selection"
    for sel in "${selections[@]}"; do
        sel=$(echo "$sel" | tr -d '[:space:]')
        if [[ "$sel" =~ ^[0-9]+$ ]] && (( sel >= 1 && sel <= ${#detected_tools[@]} )); then
            selected_tools+=("${detected_tools[$((sel - 1))]}")
        fi
    done
fi

if [[ ${#selected_tools[@]} -eq 0 ]]; then
    print_info "No tools selected. Exiting."
    exit 0
fi

# ---- install functions -----------------------------------------------------

install_claude_commands() {
    local src_dir=".claude/commands"
    local dest_dir="$HOME/.claude/commands"
    local marker="$MD_MARKER"
    local installed=0 updated=0 skipped=0

    if [[ ! -d "$src_dir" ]]; then
        print_warning "No Claude commands found in $src_dir/"
        return
    fi

    local files=()
    while IFS= read -r -d '' f; do
        files+=("$f")
    done < <(find "$src_dir" -name "*.md" -print0 | sort -z)

    if [[ ${#files[@]} -eq 0 ]]; then
        print_warning "No .md files found in $src_dir/"
        return
    fi

    echo ""
    echo -e "${BOLD}── Claude Code ──${NC}"
    echo ""

    if ! prompt_yes_no "Install Claude Code commands? (${#files[@]} available)"; then
        print_info "Skipped Claude Code."
        return
    fi

    echo ""
    mkdir -p "$dest_dir"

    for src_file in "${files[@]}"; do
        local filename
        filename=$(basename "$src_file")
        local cmd_name="${filename%.md}"
        local dest_file="$dest_dir/$filename"
        local desc
        desc=$(get_md_description "$src_file")

        echo -e "  ${BOLD}/${cmd_name}${NC}"
        echo -e "  ${desc}"
        echo ""

        if [[ -f "$dest_file" ]]; then
            if has_md_marker "$dest_file"; then
                if prompt_yes_no "  Already installed by ai-coding-setup. Update?"; then
                    cp "$src_file" "$dest_file"
                    if ! has_md_marker "$dest_file"; then
                        printf '\n%s\n' "$marker" >> "$dest_file"
                    fi
                    print_success "Updated /${cmd_name}"
                    ((updated++))
                else
                    print_info "Skipped /${cmd_name}"
                    ((skipped++))
                fi
            else
                print_warning "/${cmd_name} already exists and was NOT installed by this script."
                echo -e "  ${YELLOW}Skipping to avoid overwriting your custom command.${NC}"
                ((skipped++))
            fi
        else
            if prompt_yes_no "  Install this command?"; then
                cp "$src_file" "$dest_file"
                printf '\n%s\n' "$marker" >> "$dest_file"
                print_success "Installed /${cmd_name}"
                ((installed++))
            else
                print_info "Skipped /${cmd_name}"
                ((skipped++))
            fi
        fi
        echo ""
    done

    echo -e "  ${BOLD}Claude Code:${NC} $installed installed, $updated updated, $skipped skipped"
}

install_gemini_commands() {
    local src_dir=".gemini/commands"
    local dest_dir="$HOME/.gemini/commands"
    local marker="$TOML_MARKER"
    local installed=0 updated=0 skipped=0

    if [[ ! -d "$src_dir" ]]; then
        print_warning "No Gemini commands found in $src_dir/"
        return
    fi

    local files=()
    while IFS= read -r -d '' f; do
        files+=("$f")
    done < <(find "$src_dir" -name "*.toml" -print0 | sort -z)

    if [[ ${#files[@]} -eq 0 ]]; then
        print_warning "No .toml files found in $src_dir/"
        return
    fi

    echo ""
    echo -e "${BOLD}── Gemini CLI ──${NC}"
    echo ""

    if ! prompt_yes_no "Install Gemini CLI commands? (${#files[@]} available)"; then
        print_info "Skipped Gemini CLI."
        return
    fi

    echo ""
    mkdir -p "$dest_dir"

    for src_file in "${files[@]}"; do
        local filename
        filename=$(basename "$src_file")
        local cmd_name="${filename%.toml}"
        local dest_file="$dest_dir/$filename"
        local desc
        desc=$(get_toml_description "$src_file")

        echo -e "  ${BOLD}/${cmd_name}${NC}"
        echo -e "  ${desc}"
        echo ""

        if [[ -f "$dest_file" ]]; then
            if has_toml_marker "$dest_file"; then
                if prompt_yes_no "  Already installed by ai-coding-setup. Update?"; then
                    cp "$src_file" "$dest_file"
                    if ! has_toml_marker "$dest_file"; then
                        printf '\n%s\n' "$marker" >> "$dest_file"
                    fi
                    print_success "Updated /${cmd_name}"
                    ((updated++))
                else
                    print_info "Skipped /${cmd_name}"
                    ((skipped++))
                fi
            else
                print_warning "/${cmd_name} already exists and was NOT installed by this script."
                echo -e "  ${YELLOW}Skipping to avoid overwriting your custom command.${NC}"
                ((skipped++))
            fi
        else
            if prompt_yes_no "  Install this command?"; then
                cp "$src_file" "$dest_file"
                printf '\n%s\n' "$marker" >> "$dest_file"
                print_success "Installed /${cmd_name}"
                ((installed++))
            else
                print_info "Skipped /${cmd_name}"
                ((skipped++))
            fi
        fi
        echo ""
    done

    echo -e "  ${BOLD}Gemini CLI:${NC} $installed installed, $updated updated, $skipped skipped"
}

install_codex_skills() {
    local src_dir=".codex/skills"
    local dest_dir="$HOME/.codex/skills"
    local marker="$MD_MARKER"
    local installed=0 updated=0 skipped=0

    if [[ ! -d "$src_dir" ]]; then
        print_warning "No Codex skills found in $src_dir/"
        return
    fi

    # Find skill directories (each must contain SKILL.md)
    local skill_dirs=()
    while IFS= read -r -d '' d; do
        if [[ -f "$d/SKILL.md" ]]; then
            skill_dirs+=("$d")
        fi
    done < <(find "$src_dir" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)

    if [[ ${#skill_dirs[@]} -eq 0 ]]; then
        print_warning "No skills with SKILL.md found in $src_dir/"
        return
    fi

    echo ""
    echo -e "${BOLD}── Codex CLI ──${NC}"
    echo ""

    if ! prompt_yes_no "Install Codex CLI skills? (${#skill_dirs[@]} available)"; then
        print_info "Skipped Codex CLI."
        return
    fi

    echo ""
    mkdir -p "$dest_dir"

    for src_skill_dir in "${skill_dirs[@]}"; do
        local skill_name
        skill_name=$(basename "$src_skill_dir")
        local dest_skill_dir="$dest_dir/$skill_name"
        local src_skill_md="$src_skill_dir/SKILL.md"
        local dest_skill_md="$dest_skill_dir/SKILL.md"
        local desc
        desc=$(get_skill_description "$src_skill_md")

        echo -e "  ${BOLD}\$${skill_name}${NC}"
        echo -e "  ${desc}"
        echo ""

        if [[ -d "$dest_skill_dir" ]] && [[ -f "$dest_skill_md" ]]; then
            if has_md_marker "$dest_skill_md"; then
                if prompt_yes_no "  Already installed by ai-coding-setup. Update?"; then
                    rm -rf "$dest_skill_dir"
                    cp -r "$src_skill_dir" "$dest_skill_dir"
                    if ! has_md_marker "$dest_skill_md"; then
                        printf '\n%s\n' "$marker" >> "$dest_skill_md"
                    fi
                    print_success "Updated \$${skill_name}"
                    ((updated++))
                else
                    print_info "Skipped \$${skill_name}"
                    ((skipped++))
                fi
            else
                print_warning "\$${skill_name} already exists and was NOT installed by this script."
                echo -e "  ${YELLOW}Skipping to avoid overwriting your custom skill.${NC}"
                ((skipped++))
            fi
        else
            if prompt_yes_no "  Install this skill?"; then
                cp -r "$src_skill_dir" "$dest_skill_dir"
                printf '\n%s\n' "$marker" >> "$dest_skill_md"
                print_success "Installed \$${skill_name}"
                ((installed++))
            else
                print_info "Skipped \$${skill_name}"
                ((skipped++))
            fi
        fi
        echo ""
    done

    echo -e "  ${BOLD}Codex CLI:${NC} $installed installed, $updated updated, $skipped skipped"
}

# ---- run installs ----------------------------------------------------------

for tool in "${selected_tools[@]}"; do
    case "$tool" in
        claude) install_claude_commands ;;
        gemini) install_gemini_commands ;;
        codex)  install_codex_skills ;;
    esac
done

# ---- final summary ---------------------------------------------------------

echo ""
echo -e "${BOLD}=== Done ===${NC}"
echo ""
echo "Use your commands in:"

for tool in "${selected_tools[@]}"; do
    case "$tool" in
        claude) echo -e "  Claude Code — type ${BOLD}/command-name${NC} in the prompt" ;;
        gemini) echo -e "  Gemini CLI  — type ${BOLD}/command-name${NC} in the prompt" ;;
        codex)  echo -e "  Codex CLI   — type ${BOLD}\$skill-name${NC} to invoke a skill" ;;
    esac
done
echo ""
