#!/usr/bin/env bash
# source: ai-coding-setup
# ---------------------------------------------------------------------------
# Automated plan review feedback loop.
#
# Orchestrates an iterative plan improvement cycle:
#   1. Reviewer agent reads plan file, writes structured feedback to feedback-plan.md
#   2. Editor agent reads plan + feedback, improves plan, writes response
#   3. Reviewer re-reviews, provides new feedback or signals NO_FURTHER_FEEDBACK
#   4. Repeat until satisfied or max iterations
#   5. Claude writes a narrative summary to plan-review-summary.md
#
# Agent roles are configurable via ~/.ai-coding-setup.conf and CLI flags.
# ---------------------------------------------------------------------------
set -euo pipefail

# ---- load shared library --------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=lib/lib-review-loop
source "$SCRIPT_DIR/../lib/lib-review-loop"

# ---- defaults (hardcoded -> config file -> CLI flags) ---------------------
EDITOR_AGENT="claude"
REVIEWER_AGENT="codex"
load_config

MAX_ITERATIONS=5
PLAN_FILE=""

# Track whether CLI explicitly set agents (to preserve override over config)
_CLI_EDITOR="" _CLI_REVIEWER=""

# ---- usage ---------------------------------------------------------------
usage() {
    cat <<'EOF'
Usage: plan-review-loop [OPTIONS] <plan-file>

Orchestrates a plan review feedback loop between two AI agents.

Arguments:
  plan-file                Path to the plan document to review

Options:
  -m, --max-iterations N   Maximum review-improve cycles (default: 5)
  -e, --editor AGENT       Agent for plan improvement (default: claude)
  -r, --reviewer AGENT     Agent for plan review (default: codex)
  -h, --help               Show this help message

Agents: claude, codex, gemini

Examples:
  plan-review-loop PLAN-feature.md
  plan-review-loop -m 3 PLAN-feature.md
  plan-review-loop --reviewer claude --editor codex PLAN-feature.md
EOF
    exit 0
}

# ---- argument parsing ----------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        -m|--max-iterations) [[ $# -ge 2 ]] || { echo -e "${RED}ERROR: $1 requires a value${NC}"; usage; }; MAX_ITERATIONS="$2"; shift 2 ;;
        -e|--editor)   [[ $# -ge 2 ]] || { echo -e "${RED}ERROR: $1 requires a value${NC}"; usage; }; _CLI_EDITOR="$2"; shift 2 ;;
        -r|--reviewer) [[ $# -ge 2 ]] || { echo -e "${RED}ERROR: $1 requires a value${NC}"; usage; }; _CLI_REVIEWER="$2"; shift 2 ;;
        -h|--help) usage ;;
        -*) echo -e "${RED}Unknown option: $1${NC}"; usage ;;
        *)  PLAN_FILE="$1"; shift ;;
    esac
done

# CLI flags override config file
[[ -n "$_CLI_EDITOR" ]]   && EDITOR_AGENT="$_CLI_EDITOR"
[[ -n "$_CLI_REVIEWER" ]] && REVIEWER_AGENT="$_CLI_REVIEWER"

validate_agent_name "$EDITOR_AGENT" "--editor"
validate_agent_name "$REVIEWER_AGENT" "--reviewer"
validate_positive_int "$MAX_ITERATIONS" "--max-iterations"

if [[ -z "$PLAN_FILE" ]]; then
    echo -e "${RED}ERROR: Plan file argument is required${NC}"
    echo ""
    usage
fi

# ---- paths ---------------------------------------------------------------
PROJECT_ROOT="$(pwd)"
FEEDBACK_FILE="$PROJECT_ROOT/feedback-plan.md"
if [[ "$PLAN_FILE" == /* || "$PLAN_FILE" == ?:* ]]; then
    PLAN_FILE_PATH="$PLAN_FILE"
else
    PLAN_FILE_PATH="$PROJECT_ROOT/$PLAN_FILE"
fi

REVIEWER_INITIAL_PROMPT="$PROMPTS_DIR/plan-review.md"
REVIEWER_FOLLOWUP_PROMPT="$PROMPTS_DIR/plan-review-followup.md"

EDITOR_TOOLS="Read,Write,Edit,Grep,Glob"
REVIEWER_TOOLS="Read,Write,Grep,Glob"

# ---- helpers -------------------------------------------------------------

test_reviewer_satisfied() {
    [[ -f "$FEEDBACK_FILE" ]] || return 1
    # Match sentinel as a standalone line to avoid false positives from
    # feedback that merely mentions the token in explanatory text
    local trimmed
    trimmed=$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' -e '/^$/d' "$FEEDBACK_FILE")
    [[ "$trimmed" == "NO_FURTHER_FEEDBACK" ]]
}

build_improvement_prompt() {
    local plan_path="$1" feedback_path="$2" reviewer_name="$3" cycle="$4" max_cycles="$5"
    cat <<PROMPT
You are a senior software architect improving a plan document based on reviewer feedback.

## Your Task

1. **Read** the plan file: $plan_path
2. **Read** the feedback file: $feedback_path
3. **Evaluate** each feedback point critically. You are NOT obligated to accept every suggestion. Use your judgment:
   - Accept and implement feedback that genuinely improves completeness, feasibility, clarity, or risk coverage.
   - Decline feedback that is subjective preference, out of scope, or would degrade the plan.
4. **Edit** the plan file directly to incorporate valid improvements. Do not rewrite sections that are already well-structured unless the feedback identifies a real gap.
5. **Write** a response to $feedback_path (overwrite it) explaining your actions:
   - For each accepted point: briefly describe what was changed and where.
   - For each declined point: explain why (e.g., out of scope, already covered, disagree with reasoning).

## Response Format

Use these markers for each feedback item in your response:

- Accepted: \`✅ Implemented: [brief description of what was changed]\`
- Deferred: \`📝 Response: [reason for deferring, alternatives]\`
- Declined: \`❌ Clarification: [reason for disagreeing]\`

## Guidelines

- Preserve the plan's existing structure and formatting conventions.
- Do not add unnecessary boilerplate or padding.
- Focus on substance: missing edge cases, risk gaps, unclear requirements, feasibility concerns.
- If the reviewer's feedback is entirely minor or already addressed, say so clearly in your response.
- This is cycle $cycle of $max_cycles with the $reviewer_name reviewer.

## Output

Your only output files are:
- The improved plan file (edited in place)
- The feedback response file (overwritten with your response)

Do not create any other files. Do not stage or commit anything.
PROMPT
}

# ---- validation ----------------------------------------------------------
if [[ ! -f "$PLAN_FILE_PATH" ]]; then
    echo -e "${RED}ERROR: Plan file not found: $PLAN_FILE_PATH${NC}"
    exit 1
fi

validate_tools
validate_prompts "$REVIEWER_INITIAL_PROMPT" "$REVIEWER_FOLLOWUP_PROMPT"

# ---- temp directory with cleanup -----------------------------------------
setup_temp "plan-review-loop"
trap cleanup_temp EXIT

# ---- main ----------------------------------------------------------------

echo ""
echo -e "${MAGENTA}========================================${NC}"
echo -e "${MAGENTA} Plan Review Loop${NC}"
echo -e "${MAGENTA}========================================${NC}"
echo " Plan file      : $PLAN_FILE"
echo " Max iterations : $MAX_ITERATIONS"
echo " Editor          : $EDITOR_AGENT"
echo " Reviewer        : $REVIEWER_AGENT"

start_time=$(date +%s)
iteration_data=""
reviewer_iterations=0
reviewer_satisfied=false

# Snapshot the original plan for the summary diff
cp "$PLAN_FILE_PATH" "$TMPDIR_REVIEW/plan-initial.md"

# =========================================================================
# Review Loop
# =========================================================================
echo ""
echo -e "${YELLOW}----------------------------------------${NC}"
echo -e "${YELLOW} $REVIEWER_AGENT Review${NC}"
echo -e "${YELLOW}----------------------------------------${NC}"

# ---- Initial review ------------------------------------------------------
write_step "1" "$REVIEWER_AGENT: Initial Plan Review"
rm -f "$FEEDBACK_FILE" 2>/dev/null || true
write_status "This may take several minutes..." "$DIM"

reviewer_prompt=$(read_prompt_file "$REVIEWER_INITIAL_PROMPT")
review_task="$reviewer_prompt

IMPORTANT: You MUST write your review to the file feedback-plan.md in the project root. Do NOT create any other files.
The plan file to review is: $PLAN_FILE"

pre_snapshot="$TMPDIR_REVIEW/pre-review-initial.txt"
snapshot_untracked > "$pre_snapshot"

local_exit=0
run_agent "$REVIEWER_AGENT" "$review_task" "$REVIEWER_TOOLS" || local_exit=$?
cleanup_agent_artifacts "$REVIEWER_AGENT" "$pre_snapshot" "reviewer"

if [[ $local_exit -ne 0 ]]; then
    write_status "$REVIEWER_AGENT plan review exited with code $local_exit" "$YELLOW"
fi

if [[ ! -f "$FEEDBACK_FILE" ]]; then
    write_status "No feedback file created — $REVIEWER_AGENT may have failed" "$RED"
    echo ""
    echo -e "${MAGENTA}========================================${NC}"
    echo -e "${MAGENTA} Plan Review Loop Complete${NC}"
    echo -e "${MAGENTA}========================================${NC}"
    echo " Status   : ERROR (feedback file not generated)"
    echo ""
    echo -e "${RED}$REVIEWER_AGENT did not produce feedback-plan.md. Plan is NOT reviewed.${NC}"
    exit 1
fi

feedback_content=$(<"$FEEDBACK_FILE")
iteration_data+=$'\n### Initial Review\n\n'
iteration_data+="$feedback_content"$'\n'

# ---- Feedback loop -------------------------------------------------------
while [[ $reviewer_iterations -lt $MAX_ITERATIONS ]]; do
    if test_reviewer_satisfied; then
        write_status "$REVIEWER_AGENT is satisfied — no further feedback!" "$GREEN"
        reviewer_satisfied=true
        break
    fi

    reviewer_iterations=$((reviewer_iterations + 1))
    echo ""
    echo -e "${YELLOW}=== Review Cycle $reviewer_iterations of $MAX_ITERATIONS ===${NC}"

    # Editor improves the plan
    write_step "2.$reviewer_iterations" "$EDITOR_AGENT: Improving Plan ($REVIEWER_AGENT feedback)"
    write_status "This may take several minutes..." "$DIM"

    editor_prompt=$(build_improvement_prompt \
        "$PLAN_FILE_PATH" "$FEEDBACK_FILE" "$REVIEWER_AGENT" "$reviewer_iterations" "$MAX_ITERATIONS")

    pre_snapshot="$TMPDIR_REVIEW/pre-editor-cycle-$reviewer_iterations.txt"
    snapshot_untracked > "$pre_snapshot"

    local_exit=0
    run_agent "$EDITOR_AGENT" "$editor_prompt" "$EDITOR_TOOLS" || local_exit=$?
    cleanup_agent_artifacts "$EDITOR_AGENT" "$pre_snapshot" "editor"

    if [[ $local_exit -ne 0 ]]; then
        write_status "$EDITOR_AGENT plan improvement exited with code $local_exit" "$YELLOW"
    fi

    # Capture editor's response
    editor_response=""
    if [[ -f "$FEEDBACK_FILE" ]]; then
        editor_response=$(<"$FEEDBACK_FILE")
    fi
    iteration_data+=$'\n### Cycle '"$reviewer_iterations"$' - Editor Response\n\n'
    # Truncate very long feedback to keep the summary prompt reasonable
    if [[ ${#editor_response} -gt 3000 ]]; then
        iteration_data+="${editor_response:0:3000}"$'\n\n... (truncated)\n'
    else
        iteration_data+="$editor_response"$'\n'
    fi

    # Reviewer follow-up review
    write_step "3.$reviewer_iterations" "$REVIEWER_AGENT: Follow-up Review"
    write_status "This may take several minutes..." "$DIM"

    followup_prompt=$(read_prompt_file "$REVIEWER_FOLLOWUP_PROMPT")
    followup_task="$followup_prompt

The plan file is: $PLAN_FILE
IMPORTANT: Write ALL output (feedback or NO_FURTHER_FEEDBACK) to the file feedback-plan.md. Do NOT create any other files."

    pre_snapshot="$TMPDIR_REVIEW/pre-review-cycle-$reviewer_iterations.txt"
    snapshot_untracked > "$pre_snapshot"

    local_exit=0
    run_agent "$REVIEWER_AGENT" "$followup_task" "$REVIEWER_TOOLS" || local_exit=$?
    cleanup_agent_artifacts "$REVIEWER_AGENT" "$pre_snapshot" "reviewer"

    if [[ $local_exit -ne 0 ]]; then
        write_status "$REVIEWER_AGENT follow-up failed (exit $local_exit) — aborting review loop" "$YELLOW"
        break
    fi

    # Capture reviewer follow-up feedback
    reviewer_followup=""
    if [[ -f "$FEEDBACK_FILE" ]]; then
        reviewer_followup=$(<"$FEEDBACK_FILE")
    fi
    iteration_data+=$'\n### Cycle '"$reviewer_iterations"$' - Reviewer Follow-up\n\n'
    if [[ ${#reviewer_followup} -gt 3000 ]]; then
        iteration_data+="${reviewer_followup:0:3000}"$'\n\n... (truncated)\n'
    else
        iteration_data+="$reviewer_followup"$'\n'
    fi
done

if [[ "$reviewer_satisfied" == false ]] && [[ $reviewer_iterations -ge $MAX_ITERATIONS ]]; then
    write_status "$REVIEWER_AGENT: Max iterations ($MAX_ITERATIONS) reached" "$YELLOW"
fi

# ---- Build improvement history for the summary --------------------------
elapsed_display=$(format_elapsed "$start_time")

# Read final feedback file
final_feedback=""
if [[ -f "$FEEDBACK_FILE" ]]; then
    final_feedback=$(<"$FEEDBACK_FILE")
fi

# Diff initial vs final plan
plan_diff=$(git diff --no-index -- "$TMPDIR_REVIEW/plan-initial.md" "$PLAN_FILE_PATH" 2>&1) || true

write_status "Plan diff saved for summary agent" "$DIM"

# ---- Editor writes the improvement summary --------------------------------
write_step "Final" "$EDITOR_AGENT: Writing plan improvement summary"

if $reviewer_satisfied; then
    reviewer_status_label="satisfied"
else
    reviewer_status_label="max iterations reached"
fi

summary_prompt="Write a narrative summary of plan improvements to the file plan-review-summary.md in the project root.

This was an automated plan review loop that ran in $elapsed_display.
Plan file: $PLAN_FILE
Reviewer: $REVIEWER_AGENT ($reviewer_iterations cycle(s), $reviewer_status_label)
Editor: $EDITOR_AGENT

## Plan Diff (before vs after review loop)

This is the unified diff of the plan file showing exactly what the review loop changed:

$plan_diff

## Iteration History

The following is a chronological log of every review and response cycle. Use this to understand what feedback was given, what was accepted/declined, and how the plan evolved.

$iteration_data

## Final Feedback File
$final_feedback

## Instructions for the summary

Your job is to summarize what the REVIEW LOOP changed in the plan — use the diff above as the primary source of truth.

Write plan-review-summary.md with this structure:

1. **Overview** - One paragraph summarizing what the review loop accomplished and the overall quality trajectory of the plan.
2. **Key Improvements** - Narrative bullets describing the most significant improvements made to the plan. Focus on WHAT changed and WHY (e.g., \"Added rollback strategy for database migration\" not \"Edited Sprint R3 section\"). Group related improvements together.
3. **Declined Feedback** - Brief summary of feedback that was considered but declined, and the reasoning. Only include if there were notable declinations.
4. **Remaining Gaps** (if any) - Anything the reviewers flagged that was not fully resolved.
5. **Review Metrics** - Cycles, whether $REVIEWER_AGENT was satisfied, total duration.

Be concise and focus on the substance of improvements, not process details.
Do not create any other files. Do not stage or commit anything."

local_exit=0
run_agent "$EDITOR_AGENT" "$summary_prompt" "Read,Write,Grep,Glob" || local_exit=$?

# ---- Cleanup intermediate files -----------------------------------------
# Only remove feedback file when it contains no valid content (NO_FURTHER_FEEDBACK)
if $reviewer_satisfied; then
    rm -f "$FEEDBACK_FILE"
fi

# ---- Done ----------------------------------------------------------------
echo ""
echo -e "${MAGENTA}========================================${NC}"
echo -e "${MAGENTA} Plan Review Loop Complete${NC}"
echo -e "${MAGENTA}========================================${NC}"
echo ""

if $reviewer_satisfied; then
    echo -e " Reviewer : ${GREEN}$REVIEWER_AGENT — SATISFIED (NO_FURTHER_FEEDBACK)  [$reviewer_iterations iteration(s)]${NC}"
else
    echo -e " Reviewer : ${YELLOW}$REVIEWER_AGENT — MAX ITERATIONS ($MAX_ITERATIONS)  [$reviewer_iterations iteration(s)]${NC}"
fi

echo ""
echo " Duration : $elapsed_display"
echo " Editor   : $EDITOR_AGENT"
echo -e " Plan     : $PLAN_FILE"
[[ -f "$FEEDBACK_FILE" ]] && echo -e " Feedback : feedback-plan.md"
echo -e " Summary  : plan-review-summary.md"
echo ""
echo -e "${CYAN}Review the improved plan and summary.${NC}"
