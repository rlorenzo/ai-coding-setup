#!/usr/bin/env bash
# source: ai-coding-setup
# ---------------------------------------------------------------------------
# Automated plan review feedback loop using Codex and Claude.
#
# Orchestrates an iterative plan improvement cycle:
#   1. Codex reads plan file, writes structured feedback to feedback-plan.md
#   2. Claude reads plan + feedback, improves plan, writes response
#   3. Codex re-reviews, provides new feedback or signals NO_FURTHER_FEEDBACK
#   4. Repeat until satisfied or max iterations
#   5. Claude writes a narrative summary to plan-review-summary.md
# ---------------------------------------------------------------------------
set -euo pipefail

# ---- colours (disabled when stdout is not a terminal) --------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
DIM='\033[2m'
NC='\033[0m'

if [[ ! -t 1 ]]; then
    RED='' GREEN='' YELLOW='' CYAN='' MAGENTA='' DIM='' NC=''
fi

# ---- defaults ------------------------------------------------------------
MAX_ITERATIONS=5
PLAN_FILE=""

# ---- usage ---------------------------------------------------------------
usage() {
    cat <<'EOF'
Usage: plan-review-loop [OPTIONS] <plan-file>

Orchestrates a plan review feedback loop between Codex CLI and Claude Code.

Arguments:
  plan-file                Path to the plan document to review

Options:
  -m, --max-iterations N   Maximum review-improve cycles (default: 5)
  -h, --help               Show this help message

Examples:
  plan-review-loop PLAN-feature.md
  plan-review-loop -m 3 PLAN-feature.md
EOF
    exit 0
}

# ---- argument parsing ----------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        -m|--max-iterations) [[ $# -ge 2 ]] || { echo -e "${RED}ERROR: $1 requires a value${NC}"; usage; }; MAX_ITERATIONS="$2"; shift 2 ;;
        -h|--help) usage ;;
        -*) echo -e "${RED}Unknown option: $1${NC}"; usage ;;
        *)  PLAN_FILE="$1"; shift ;;
    esac
done

if [[ -z "$PLAN_FILE" ]]; then
    echo -e "${RED}ERROR: Plan file argument is required${NC}"
    echo ""
    usage
fi

# ---- paths ---------------------------------------------------------------
PROJECT_ROOT="$(pwd)"
FEEDBACK_FILE="$PROJECT_ROOT/feedback-plan.md"
if [[ "$PLAN_FILE" == /* || "$PLAN_FILE" == ?:* ]]; then
    PLAN_FILE_PATH="$PLAN_FILE"
else
    PLAN_FILE_PATH="$PROJECT_ROOT/$PLAN_FILE"
fi

CODEX_REVIEW_PROMPT="$HOME/.codex/prompts/plan-review.md"
CODEX_FOLLOWUP_PROMPT="$HOME/.codex/prompts/plan-review-followup.md"

CLAUDE_TOOLS="Read,Write,Edit,Grep,Glob"

# ---- helpers -------------------------------------------------------------
write_step() {
    local label="$1" message="$2"
    echo ""
    echo -e "${CYAN}[$label] $message${NC}"
    printf '%0.s-' {1..60}
    echo ""
}

write_status() {
    local message="$1" color="${2:-${NC}}"
    echo -e "  ${color}${message}${NC}"
}

read_prompt_file() {
    local path="$1"
    local content
    content=$(<"$path")
    # Strip YAML frontmatter if present (---\n...\n---\n)
    if [[ "$content" == ---* ]]; then
        content=$(printf '%s\n' "$content" | sed '1{/^---/d}; 1,/^---/d')
    fi
    # Trim leading/trailing blank lines only (preserve indentation within)
    content=$(printf '%s\n' "$content" | sed -e '/./,$!d' | sed -e ':a' -e '/^[[:space:]]*$/{ $d; N; ba; }')
    printf '%s' "$content"
}

test_reviewer_satisfied() {
    [[ -f "$FEEDBACK_FILE" ]] || return 1
    # Match sentinel as a standalone line to avoid false positives from
    # feedback that merely mentions the token in explanatory text
    local trimmed
    trimmed=$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' -e '/^$/d' "$FEEDBACK_FILE")
    [[ "$trimmed" == "NO_FURTHER_FEEDBACK" ]]
}

build_claude_improvement_prompt() {
    local plan_path="$1" feedback_path="$2" reviewer_name="$3" cycle="$4" max_cycles="$5"
    cat <<PROMPT
You are a senior software architect improving a plan document based on reviewer feedback.

## Your Task

1. **Read** the plan file: $plan_path
2. **Read** the feedback file: $feedback_path
3. **Evaluate** each feedback point critically. You are NOT obligated to accept every suggestion. Use your judgment:
   - Accept and implement feedback that genuinely improves completeness, feasibility, clarity, or risk coverage.
   - Decline feedback that is subjective preference, out of scope, or would degrade the plan.
4. **Edit** the plan file directly to incorporate valid improvements. Do not rewrite sections that are already well-structured unless the feedback identifies a real gap.
5. **Write** a response to $feedback_path (overwrite it) explaining your actions:
   - For each accepted point: briefly describe what was changed and where.
   - For each declined point: explain why (e.g., out of scope, already covered, disagree with reasoning).

## Response Format

Use these markers for each feedback item in your response:

- Accepted: \`✅ Implemented: [brief description of what was changed]\`
- Deferred: \`📝 Response: [reason for deferring, alternatives]\`
- Declined: \`❌ Clarification: [reason for disagreeing]\`

## Guidelines

- Preserve the plan's existing structure and formatting conventions.
- Do not add unnecessary boilerplate or padding.
- Focus on substance: missing edge cases, risk gaps, unclear requirements, feasibility concerns.
- If the reviewer's feedback is entirely minor or already addressed, say so clearly in your response.
- This is cycle $cycle of $max_cycles with the $reviewer_name reviewer.

## Output

Your only output files are:
- The improved plan file (edited in place)
- The feedback response file (overwritten with your response)

Do not create any other files. Do not stage or commit anything.
PROMPT
}

# ---- validation ----------------------------------------------------------
if [[ ! -f "$PLAN_FILE_PATH" ]]; then
    echo -e "${RED}ERROR: Plan file not found: $PLAN_FILE_PATH${NC}"
    exit 1
fi

validate_tools() {
    local missing=()
    command -v claude &>/dev/null || missing+=("claude")
    command -v codex &>/dev/null || missing+=("codex")
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}ERROR: Missing required tools: ${missing[*]}${NC}"
        echo "  Install Claude Code: https://docs.anthropic.com/en/docs/claude-code"
        echo "  Install Codex CLI:   https://github.com/openai/codex"
        exit 1
    fi
}

validate_prompts() {
    local missing=()
    [[ -f "$CODEX_REVIEW_PROMPT" ]] || missing+=("$CODEX_REVIEW_PROMPT")
    [[ -f "$CODEX_FOLLOWUP_PROMPT" ]] || missing+=("$CODEX_FOLLOWUP_PROMPT")

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}ERROR: Missing prompt files:${NC}"
        local f
        for f in "${missing[@]}"; do
            echo "  $f"
        done
        echo ""
        echo "Run the ai-coding-setup installer to install them:"
        echo "  https://github.com/rlorenzo/ai-coding-setup"
        exit 1
    fi
}

# ---- temp directory with cleanup -----------------------------------------
TMPDIR_REVIEW=""

setup_temp() {
    TMPDIR_REVIEW=$(mktemp -d "${TMPDIR:-/tmp}/plan-review-loop.XXXXXX")
}

cleanup() {
    [[ -n "$TMPDIR_REVIEW" ]] && rm -rf "$TMPDIR_REVIEW"
}
trap cleanup EXIT

# ---- main ----------------------------------------------------------------
validate_tools
validate_prompts
setup_temp

echo ""
echo -e "${MAGENTA}========================================${NC}"
echo -e "${MAGENTA} Plan Review Loop${NC}"
echo -e "${MAGENTA}========================================${NC}"
echo " Plan file     : $PLAN_FILE"
echo " Max iterations: $MAX_ITERATIONS"

start_time=$(date +%s)
iteration_data=""
codex_iterations=0
codex_satisfied=false

# Snapshot the original plan for the summary diff
cp "$PLAN_FILE_PATH" "$TMPDIR_REVIEW/plan-initial.md"

# =========================================================================
# Codex Review
# =========================================================================
echo ""
echo -e "${YELLOW}----------------------------------------${NC}"
echo -e "${YELLOW} Codex Review${NC}"
echo -e "${YELLOW}----------------------------------------${NC}"

# ---- Initial Codex review ------------------------------------------------
write_step "1" "Codex: Initial Plan Review"
rm -f "$FEEDBACK_FILE" 2>/dev/null || true
write_status "This may take several minutes..." "$DIM"

codex_prompt=$(read_prompt_file "$CODEX_REVIEW_PROMPT")
codex_task="Execute the following plan review task now. Do not introduce yourself. Begin immediately.
IMPORTANT: You MUST write your review to the file feedback-plan.md in the project root. Do NOT create any other files.
The plan file to review is: $PLAN_FILE

$codex_prompt"

local_exit=0
echo "$codex_task" | codex exec --full-auto - || local_exit=$?

if [[ $local_exit -ne 0 ]]; then
    write_status "Codex plan review exited with code $local_exit" "$YELLOW"
fi

if [[ ! -f "$FEEDBACK_FILE" ]]; then
    write_status "No feedback file created — Codex may have failed" "$RED"
    echo ""
    echo -e "${MAGENTA}========================================${NC}"
    echo -e "${MAGENTA} Plan Review Loop Complete${NC}"
    echo -e "${MAGENTA}========================================${NC}"
    echo " Status   : ERROR (feedback file not generated)"
    echo ""
    echo -e "${RED}Codex did not produce feedback-plan.md. Plan is NOT reviewed.${NC}"
    exit 1
fi

feedback_content=$(<"$FEEDBACK_FILE")
iteration_data+=$'\n### Codex Initial Review\n\n'
iteration_data+="$feedback_content"$'\n'

# ---- Codex feedback loop -------------------------------------------------
while [[ $codex_iterations -lt $MAX_ITERATIONS ]]; do
    if test_reviewer_satisfied; then
        write_status "Codex is satisfied — no further feedback!" "$GREEN"
        codex_satisfied=true
        break
    fi

    codex_iterations=$((codex_iterations + 1))
    echo ""
    echo -e "${YELLOW}=== Codex Review Cycle $codex_iterations of $MAX_ITERATIONS ===${NC}"

    # Claude improves the plan
    write_step "2.$codex_iterations" "Claude: Improving Plan (Codex feedback)"
    write_status "This may take several minutes..." "$DIM"

    claude_prompt=$(build_claude_improvement_prompt \
        "$PLAN_FILE_PATH" "$FEEDBACK_FILE" "Codex" "$codex_iterations" "$MAX_ITERATIONS")

    local_exit=0
    claude -p "$claude_prompt" --allowedTools "$CLAUDE_TOOLS" || local_exit=$?

    if [[ $local_exit -ne 0 ]]; then
        write_status "Claude plan improvement exited with code $local_exit" "$YELLOW"
    fi

    # Capture Claude's response
    claude_response=""
    if [[ -f "$FEEDBACK_FILE" ]]; then
        claude_response=$(<"$FEEDBACK_FILE")
    fi
    iteration_data+=$'\n### Codex Cycle '"$codex_iterations"$' - Claude Response\n\n'
    # Truncate very long feedback to keep the summary prompt reasonable
    if [[ ${#claude_response} -gt 3000 ]]; then
        iteration_data+="${claude_response:0:3000}"$'\n\n... (truncated)\n'
    else
        iteration_data+="$claude_response"$'\n'
    fi

    # Codex follow-up review
    write_step "3.$codex_iterations" "Codex: Follow-up Review"
    write_status "This may take several minutes..." "$DIM"

    followup_prompt=$(read_prompt_file "$CODEX_FOLLOWUP_PROMPT")
    followup_task="Execute the following plan review follow-up task now. Do not introduce yourself. Begin immediately.
The plan file is: $PLAN_FILE
IMPORTANT: Write ALL output (feedback or NO_FURTHER_FEEDBACK) to the file feedback-plan.md. Do NOT create any other files.

$followup_prompt"

    local_exit=0
    echo "$followup_task" | codex exec --full-auto - || local_exit=$?

    if [[ $local_exit -ne 0 ]]; then
        write_status "Codex follow-up failed (exit $local_exit) — aborting review loop" "$YELLOW"
        break
    fi

    # Capture Codex follow-up feedback
    codex_followup=""
    if [[ -f "$FEEDBACK_FILE" ]]; then
        codex_followup=$(<"$FEEDBACK_FILE")
    fi
    iteration_data+=$'\n### Codex Cycle '"$codex_iterations"$' - Codex Follow-up\n\n'
    if [[ ${#codex_followup} -gt 3000 ]]; then
        iteration_data+="${codex_followup:0:3000}"$'\n\n... (truncated)\n'
    else
        iteration_data+="$codex_followup"$'\n'
    fi
done

if [[ "$codex_satisfied" == false ]] && [[ $codex_iterations -ge $MAX_ITERATIONS ]]; then
    write_status "Codex: Max iterations ($MAX_ITERATIONS) reached" "$YELLOW"
fi

# ---- Build improvement history for the summary --------------------------
end_time=$(date +%s)
elapsed_secs=$((end_time - start_time))
elapsed_min=$((elapsed_secs / 60))
elapsed_remainder=$((elapsed_secs % 60))
elapsed_display="${elapsed_min}m ${elapsed_remainder}s"

# Read final feedback file
final_feedback=""
if [[ -f "$FEEDBACK_FILE" ]]; then
    final_feedback=$(<"$FEEDBACK_FILE")
fi

# Diff initial vs final plan
plan_diff=$(git diff --no-index -- "$TMPDIR_REVIEW/plan-initial.md" "$PLAN_FILE_PATH" 2>&1) || true

write_status "Plan diff saved for summary agent" "$DIM"

# ---- Claude writes the improvement summary --------------------------------
write_step "Final" "Claude: Writing plan improvement summary"

if $codex_satisfied; then
    codex_status_label="satisfied"
else
    codex_status_label="max iterations reached"
fi

summary_prompt="Write a narrative summary of plan improvements to the file plan-review-summary.md in the project root.

This was an automated plan review loop that ran in $elapsed_display.
Plan file: $PLAN_FILE
Reviewer: Codex ($codex_iterations cycle(s), $codex_status_label)

## Plan Diff (before vs after review loop)

This is the unified diff of the plan file showing exactly what the review loop changed:

$plan_diff

## Iteration History

The following is a chronological log of every review and response cycle. Use this to understand what feedback was given, what was accepted/declined, and how the plan evolved.

$iteration_data

## Final Feedback File
$final_feedback

## Instructions for the summary

Your job is to summarize what the REVIEW LOOP changed in the plan — use the diff above as the primary source of truth.

Write plan-review-summary.md with this structure:

1. **Overview** - One paragraph summarizing what the review loop accomplished and the overall quality trajectory of the plan.
2. **Key Improvements** - Narrative bullets describing the most significant improvements made to the plan. Focus on WHAT changed and WHY (e.g., \"Added rollback strategy for database migration\" not \"Edited Sprint R3 section\"). Group related improvements together.
3. **Declined Feedback** - Brief summary of feedback that was considered but declined, and the reasoning. Only include if there were notable declinations.
4. **Remaining Gaps** (if any) - Anything the reviewers flagged that was not fully resolved.
5. **Review Metrics** - Cycles, whether Codex was satisfied, total duration.

Be concise and focus on the substance of improvements, not process details.
Do not create any other files. Do not stage or commit anything."

local_exit=0
claude -p "$summary_prompt" --allowedTools "Read,Write,Grep,Glob" || local_exit=$?

# ---- Done ----------------------------------------------------------------
echo ""
echo -e "${MAGENTA}========================================${NC}"
echo -e "${MAGENTA} Plan Review Loop Complete${NC}"
echo -e "${MAGENTA}========================================${NC}"
echo ""

if $codex_satisfied; then
    echo -e " Codex   : ${GREEN}SATISFIED (NO_FURTHER_FEEDBACK)  [$codex_iterations iteration(s)]${NC}"
else
    echo -e " Codex   : ${YELLOW}MAX ITERATIONS ($MAX_ITERATIONS)  [$codex_iterations iteration(s)]${NC}"
fi

echo ""
echo " Duration: $elapsed_display"
echo -e " Plan    : $PLAN_FILE"
echo -e " Feedback: feedback-plan.md"
echo -e " Summary : plan-review-summary.md"
echo ""
echo -e "${CYAN}Review the improved plan and summary.${NC}"
