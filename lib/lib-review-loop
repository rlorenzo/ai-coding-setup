#!/usr/bin/env bash
# source: ai-coding-setup
# ---------------------------------------------------------------------------
# Shared library for review loop scripts (code-review-loop, plan-review-loop).
#
# Provides:
#   - Color definitions and TTY detection
#   - Output helpers (write_step, write_status)
#   - Prompt file reader (read_prompt_file)
#   - Config file loader (load_config)
#   - Agent validation and execution (validate_agent_name, run_agent, etc.)
#   - Artifact cleanup (snapshot_untracked, cleanup_agent_artifacts)
# ---------------------------------------------------------------------------

# Guard against double-sourcing
[[ -n "${_LIB_REVIEW_LOOP_LOADED:-}" ]] && return 0
_LIB_REVIEW_LOOP_LOADED=1

# ---- colors (disabled when stdout is not a terminal) ----------------------
# shellcheck disable=SC2034  # colors are used by sourcing scripts
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
DIM='\033[2m'
NC='\033[0m'

if [[ ! -t 1 ]]; then
    # shellcheck disable=SC2034
    RED='' GREEN='' YELLOW='' CYAN='' MAGENTA='' DIM='' NC=''
fi

# ---- constants ------------------------------------------------------------

# Shared prompts directory (review-loop scripts read prompts from here)
# shellcheck disable=SC2034  # used by sourcing scripts
PROMPTS_DIR="${AI_CODING_SETUP_PROMPTS_DIR:-$HOME/.local/share/ai-coding-setup/prompts}"

# Valid agent names for --editor / --reviewer flags
VALID_AGENTS="claude codex gemini copilot"

# Filenames that review loops create — never treat as agent artifacts
KNOWN_REVIEW_FILES="agent-code-review.md agent-review-summary.md feedback-plan.md plan-review-summary.md"

# ---- output helpers -------------------------------------------------------

write_step() {
    local label="$1" message="$2"
    echo ""
    echo -e "${CYAN}[$label] $message${NC}"
    printf '%0.s-' {1..60}
    echo ""
}

write_status() {
    local message="$1" color="${2:-${NC}}"
    echo -e "  ${color}${message}${NC}"
}

# ---- prompt file reader ---------------------------------------------------

read_prompt_file() {
    local path="$1"
    local content
    content=$(<"$path")
    # Strip YAML frontmatter if present (---\n...\n---)
    if [[ "$content" == ---* ]]; then
        content=$(printf '%s\n' "$content" | awk '
            NR==1 && /^---/ { skip=1; next }
            skip && /^---/ { skip=0; next }
            !skip { print }')
    fi
    # Trim leading and trailing blank lines (preserve indentation within)
    content=$(printf '%s\n' "$content" | awk '
        { lines[NR]=$0 }
        /[^[:space:]]/ { if (!first) first=NR; last=NR }
        END { for (i=first; i<=last; i++) print lines[i] }')
    printf '%s' "$content"
}

# ---- config file loader ---------------------------------------------------

# Load agent defaults from ~/.ai-coding-setup.conf.
# Only sets EDITOR_AGENT / REVIEWER_AGENT if not already overridden by CLI.
# Uses safe line-by-line parsing — never sources the file directly.
# shellcheck disable=SC2034  # variables are used by sourcing scripts
load_config() {
    local config_file="$HOME/.ai-coding-setup.conf"
    [[ -f "$config_file" ]] || return 0

    local line
    while IFS= read -r line; do
        # Skip comments and blank lines
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "${line// }" ]] && continue
        local value
        case "$line" in
            EDITOR_AGENT=*)
                value="${line#EDITOR_AGENT=}"
                EDITOR_AGENT="${value//[\"\']/}"
                ;;
            REVIEWER_AGENT=*)
                value="${line#REVIEWER_AGENT=}"
                REVIEWER_AGENT="${value//[\"\']/}"
                ;;
        esac
    done < "$config_file"
}

# ---- agent validation -----------------------------------------------------

validate_agent_name() {
    local name="$1" flag="$2"
    # shellcheck disable=SC2076
    if [[ ! " $VALID_AGENTS " =~ " $name " ]]; then
        echo -e "${RED}ERROR: Unknown agent '$name' for $flag${NC}"
        echo "  Available: $VALID_AGENTS"
        exit 1
    fi
}

# ---- input validation ----------------------------------------------------

# Validate that a value is a positive integer (for --max-iterations).
#   $1 — value to check
#   $2 — flag name (for error message)
validate_positive_int() {
    local value="$1" flag="$2"
    if ! [[ "$value" =~ ^[1-9][0-9]*$ ]]; then
        echo -e "${RED}ERROR: $flag requires a positive integer, got '$value'${NC}"
        exit 1
    fi
}

# ---- agent execution ------------------------------------------------------

# Run Claude Code with a prompt and optional tool restrictions.
# Disables all MCP servers to keep autonomous runs scoped to local work.
#   $1 — prompt text
#   $2 — comma-separated allowed tools (default: Edit,Read,Write,Bash,Grep,Glob)
run_claude() {
    local prompt="$1"
    local tools="${2:-Edit,Read,Write,Bash,Grep,Glob}"
    claude -p "$prompt" --allowedTools "$tools" \
        --strict-mcp-config --mcp-config '{"mcpServers":{}}'
}

# Run Codex CLI with a prompt.  Wraps the prompt with a preamble that prevents
# conversational output, and disables MCP servers to avoid artifact creation.
#   $1 — prompt text
run_codex() {
    local prompt="$1"
    local wrapped="Execute the following task now. Do not introduce yourself. Begin immediately.

$prompt"
    echo "$wrapped" | codex exec --full-auto --config 'mcp_servers={}' -
}

# Run Gemini CLI with a prompt in non-interactive headless mode.
# Uses --yolo for auto-approval (equivalent to Codex --full-auto).
# Disables MCP servers to avoid delays and artifact creation.
# Pipes via stdin for reliability with long prompts.
#   $1 — prompt text
run_gemini() {
    local prompt="$1"
    echo "$prompt" | gemini -p " " --yolo --allowed-mcp-server-names "__none__" \
        2> >(grep -v -E 'Warning:.*deprecated|YOLO mode|Session cleanup disabled|Loaded cached credentials' >&2)
}

# Run Copilot CLI with a prompt in non-interactive autonomous mode.
# Uses --autopilot for multi-step execution and --yolo for auto-approval.
# Disables MCP servers to keep autonomous runs scoped to local review work.
#   $1 — prompt text
run_copilot() {
    local prompt="$1"
    local -a mcp_flags=(--disable-builtin-mcps)
    local config="$HOME/.copilot/mcp-config.json"
    if [[ -f "$config" ]]; then
        while IFS= read -r name; do
            mcp_flags+=(--disable-mcp-server "$name")
        done < <(jq -r '.mcpServers // {} | keys[]' "$config" 2>/dev/null)
    fi
    copilot -p "$prompt" --autopilot --yolo "${mcp_flags[@]}"
}

# Dispatch to the appropriate agent runner.
#   $1 — agent name ("claude", "codex", "gemini", or "copilot")
#   $2 — prompt text
#   $3 — allowed tools (only used by Claude; ignored by others)
run_agent() {
    local agent="$1" prompt="$2" tools="${3:-}"
    case "$agent" in
        claude)  run_claude "$prompt" "$tools" ;;
        codex)   run_codex "$prompt" ;;
        gemini)  run_gemini "$prompt" ;;
        copilot) run_copilot "$prompt" ;;
        *)       echo -e "${RED}ERROR: Unknown agent: $agent${NC}"; return 1 ;;
    esac
}

# ---- shared validation ----------------------------------------------------

# Validate that the configured editor/reviewer agents are installed.
# Expects EDITOR_AGENT and REVIEWER_AGENT to be set by the caller.
validate_tools() {
    local missing=()
    command -v "$EDITOR_AGENT" &>/dev/null || missing+=("$EDITOR_AGENT")
    if [[ "$REVIEWER_AGENT" != "$EDITOR_AGENT" ]]; then
        command -v "$REVIEWER_AGENT" &>/dev/null || missing+=("$REVIEWER_AGENT")
    fi
    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}ERROR: Missing required tools: ${missing[*]}${NC}"
        echo "  Install Claude Code:  https://docs.anthropic.com/en/docs/claude-code"
        echo "  Install Codex CLI:    https://github.com/openai/codex"
        echo "  Install Gemini CLI:   https://github.com/google-gemini/gemini-cli"
        echo "  Install Copilot CLI:  https://docs.github.com/en/copilot/copilot-cli"
        exit 1
    fi
}

# Validate that required prompt files exist.
#   $@ — list of prompt file paths to check
validate_prompts() {
    local missing=()
    local f
    for f in "$@"; do
        [[ -f "$f" ]] || missing+=("$f")
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${RED}ERROR: Missing prompt files:${NC}"
        for f in "${missing[@]}"; do
            echo "  $f"
        done
        echo ""
        echo "Run the setup script from your ai-coding-setup clone to install them:"
        echo "  cd <path-to-ai-coding-setup> && ./setup"
        exit 1
    fi
}

# ---- review status checks ------------------------------------------------

# Check whether a code review is clean (no actionable issues).
# Requires REVIEW_FILE to be set by the caller.
# Returns 0 if the review file contains "Verdict: good to go", 1 otherwise.
test_review_clean() {
    [[ -f "$REVIEW_FILE" ]] || return 1
    local content
    content=$(<"$REVIEW_FILE")

    # Only an explicit "Verdict: good to go" line signals clean — a bare
    # substring match could false-positive on "not good to go"
    if echo "$content" | grep -qiE "verdict[[:space:]]*:[[:space:]]*good to go"; then
        return 0
    fi

    return 1
}

# Extract issue counts from a code review file.
# Requires REVIEW_FILE to be set by the caller.
# Prints: "High: N, Medium: N, Low: N" (or ? for missing counts)
get_review_issue_counts() {
    [[ -f "$REVIEW_FILE" ]] || { echo "No review file"; return; }
    local content high medium low
    content=$(<"$REVIEW_FILE")

    high=$(echo "$content" | grep -oE "High[[:space:]]*:?[[:space:]]*[0-9]+" | grep -oE "[0-9]+" | head -1) || true
    medium=$(echo "$content" | grep -oE "Medium[[:space:]]*:?[[:space:]]*[0-9]+" | grep -oE "[0-9]+" | head -1) || true
    low=$(echo "$content" | grep -oE "Low[[:space:]]*:?[[:space:]]*[0-9]+" | grep -oE "[0-9]+" | head -1) || true

    echo "High: ${high:-?}, Medium: ${medium:-?}, Low: ${low:-?}"
}

# Check whether a plan reviewer is satisfied (no further feedback).
# Requires FEEDBACK_FILE to be set by the caller.
# Returns 0 if the feedback file contains only "NO_FURTHER_FEEDBACK", 1 otherwise.
test_reviewer_satisfied() {
    [[ -f "$FEEDBACK_FILE" ]] || return 1
    # Match sentinel as a standalone line to avoid false positives from
    # feedback that merely mentions the token in explanatory text
    local trimmed
    trimmed=$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' -e '/^$/d' "$FEEDBACK_FILE")
    [[ "$trimmed" == "NO_FURTHER_FEEDBACK" ]]
}

# Build the improvement prompt for the plan editor.
#   $1 — plan file path
#   $2 — feedback file path
#   $3 — reviewer agent name
#   $4 — current cycle number
#   $5 — max cycles
build_improvement_prompt() {
    local plan_path="$1" feedback_path="$2" reviewer_name="$3" cycle="$4" max_cycles="$5"
    cat <<PROMPT
You are a senior software architect improving a plan document based on reviewer feedback.

## Your Task

1. **Read** the plan file: $plan_path
2. **Read** the feedback file: $feedback_path
3. **Evaluate** each feedback point critically. You are NOT obligated to accept every suggestion. Use your judgment:
   - Accept and implement feedback that genuinely improves completeness, feasibility, clarity, or risk coverage.
   - Decline feedback that is subjective preference, out of scope, or would degrade the plan.
4. **Edit** the plan file directly to incorporate valid improvements. Do not rewrite sections that are already well-structured unless the feedback identifies a real gap.
5. **Write** a response to $feedback_path (overwrite it) explaining your actions:
   - For each accepted point: briefly describe what was changed and where.
   - For each declined point: explain why (e.g., out of scope, already covered, disagree with reasoning).

## Response Format

Use these markers for each feedback item in your response:

- Accepted: \`✅ Implemented: [brief description of what was changed]\`
- Deferred: \`📝 Response: [reason for deferring, alternatives]\`
- Declined: \`❌ Clarification: [reason for disagreeing]\`

## Guidelines

- Preserve the plan's existing structure and formatting conventions.
- Do not add unnecessary boilerplate or padding.
- Focus on substance: missing edge cases, risk gaps, unclear requirements, feasibility concerns.
- If the reviewer's feedback is entirely minor or already addressed, say so clearly in your response.
- This is cycle $cycle of $max_cycles with the $reviewer_name reviewer.

## Output

Your only output files are:
- The improved plan file (edited in place)
- The feedback response file (overwritten with your response)

Do not create any other files. Do not stage or commit anything.
PROMPT
}

# ---- temp directory with cleanup -----------------------------------------

# Create a temp directory and register a cleanup trap.
#   $1 — prefix for the temp directory name (e.g. "code-review-loop")
# Sets: TMPDIR_REVIEW
TMPDIR_REVIEW=""

setup_temp() {
    local prefix="${1:-review-loop}"
    TMPDIR_REVIEW=$(mktemp -d "${TMPDIR:-/tmp}/${prefix}.XXXXXX")
}

cleanup_temp() {
    [[ -n "$TMPDIR_REVIEW" ]] && rm -rf "$TMPDIR_REVIEW"
}

# ---- elapsed time --------------------------------------------------------

# Compute human-readable elapsed time from a start timestamp.
#   $1 — start time (epoch seconds, from `date +%s`)
# Prints: "Xm Ys"
format_elapsed() {
    local start="$1"
    local end_time elapsed_secs elapsed_min elapsed_remainder
    end_time=$(date +%s)
    elapsed_secs=$((end_time - start))
    elapsed_min=$((elapsed_secs / 60))
    elapsed_remainder=$((elapsed_secs % 60))
    printf '%dm %ds' "$elapsed_min" "$elapsed_remainder"
}

# ---- artifact cleanup -----------------------------------------------------

# Snapshot untracked files (for detecting artifacts created during an agent run)
snapshot_untracked() {
    git ls-files --others --exclude-standard 2>/dev/null | sort
}

# Remove files that appeared during an agent run (artifacts), excluding known
# review files.  Only Codex creates artifacts; for other agents this is a no-op.
# Editor runs are always skipped — new files from the editor (tests, helpers)
# are legitimate changes that stage_review_changes will pick up.
#   $1 — agent name
#   $2 — path to the pre-run snapshot file
#   $3 — role ("editor" or "reviewer")
cleanup_agent_artifacts() {
    local agent="$1" before_file="$2" role="${3:-reviewer}"

    # Only Codex creates artifacts, and only reviewer artifacts should be cleaned.
    # Editor-created files are intentional (new tests, helper modules, etc.).
    if [[ "$agent" != "codex" ]] || [[ "$role" == "editor" ]]; then
        rm -f "$before_file"
        return 0
    fi

    local after new_files
    after=$(snapshot_untracked)
    new_files=$(comm -13 "$before_file" <(echo "$after")) || true

    if [[ -n "$new_files" ]]; then
        while IFS= read -r file; do
            [[ -z "$file" ]] && continue
            # Skip our own review files
            local base
            base=$(basename "$file")
            if [[ " $KNOWN_REVIEW_FILES " == *" $base "* ]]; then
                continue
            fi
            rm -f "$file" 2>/dev/null || true
            write_status "Removed Codex artifact: $file" "$DIM"
        done <<< "$new_files"
    fi
    rm -f "$before_file"
}
